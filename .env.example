# =============================================================================
# VisaMap (visa-map2-frontend) — пример переменных окружения
# -----------------------------------------------------------------------------
# Скопируйте в `.env.local` и подставьте значения:
#   copy .env.example .env.local   (Windows: copy .env.example .env.local)
#
# Next.js подхватывает `.env.local`, `.env.development.local`, `.env.production.local`.
# Префикс NEXT_PUBLIC_ обязателен для переменных, которые должны попасть в бандл
# браузера (остальные на клиенте будут undefined).
# =============================================================================

# --- API бэкенда (FastAPI) ----------------------------------------------------
# Базовый URL без завершающего слэша. Используется для fetch к `/countries`,
# `/travel-costs/...`, geodata и т.д.
# Примеры: http://localhost:8000  |  https://api.example.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Карта MapLibre + MapTiler ------------------------------------------------
# Ключ API MapTiler (тайлы и стили). Без ключа карта может не загрузить тайлы.
# Личный кабинет: https://cloud.maptiler.com/
NEXT_PUBLIC_MAPTILER_KEY=

# Идентификатор стиля из каталога MapTiler (см. https://cloud.maptiler.com/maps/).
# Пусто или не задано → в коде подставляется `basic-v2`.
# Важно: значения вроде `azure` в каталоге могут отсутствовать или отдавать 404.
NEXT_PUBLIC_MAPTILER_STYLE=basic-v2

# --- Отладка ------------------------------------------------------------------
# `true` или `1` — логи в консоли браузера по загрузке `/travel-costs/score-bands`
# (успех, ошибка, медленный ответ ~1.5 с). В продакшене обычно не задают.
# NEXT_PUBLIC_DEBUG_TRAVEL_COST_SCORE_BANDS=true

# =============================================================================
# Не используются в коде этого репозитория напрямую, но часто полезны при деплое
# =============================================================================

# Отключить телеметрию Next.js (опционально).
# NEXT_TELEMETRY_DISABLED=1

# Порт dev-сервера по умолчанию — 3000; меняется флагом `next dev -p 3001`, не .env.
